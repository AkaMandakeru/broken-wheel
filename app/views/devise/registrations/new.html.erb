<div class="max-w-md mx-auto py-12">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">Sign up</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :first_name, autofocus: true, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]", placeholder: "First name" %>
    </div>

    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :last_name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]", placeholder: "Last name" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, autocomplete: "email", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]", placeholder: "you@example.com" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if @minimum_password_length %>
        <span class="text-sm text-gray-500">(<%= @minimum_password_length %> characters minimum)</span>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Sign up", class: "w-full bg-[#FC4C02] text-white py-3 rounded-lg hover:bg-[#e04402] transition font-medium cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>
