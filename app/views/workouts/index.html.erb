<div class="pt-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Workouts</h1>

  <div class="grid grid-cols-2 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
      <p class="text-sm text-gray-500">Workouts</p>
      <p class="text-2xl font-bold text-gray-900"><%= @workout_count %></p>
    </div>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
      <p class="text-sm text-gray-500">Days active</p>
      <p class="text-2xl font-bold text-gray-900"><%= @unique_days %></p>
    </div>
  </div>

  <h2 class="text-lg font-semibold text-gray-900 mb-4">Active challenges</h2>
  <div class="space-y-4 mb-8">
    <% @participations.each do |participation| %>
      <%= render "shared/progress_bar", participation: participation, challenge: participation.challenge, title: participation.challenge.title %>
    <% end %>
    <% if @participations.empty? %>
      <p class="text-gray-500">No active challenges. <%= link_to "Join a challenge", challenges_path, class: "text-[#FC4C02] hover:underline" %>.</p>
    <% end %>
  </div>

  <h2 class="text-lg font-semibold text-gray-900 mb-4">Add workout</h2>
  <%= form_with model: Workout.new, url: workouts_path, local: true, html: { class: "bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8 max-w-md" } do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :sport, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :sport, [["Run", "run"], ["Bike", "bike"]], { include_blank: "Select sport" }, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4" %>
      </div>
      <div>
        <%= f.label :workout_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :workout_date, value: Date.current, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Distance</label>
        <div class="flex space-x-2">
          <%= f.number_field :distance_km_input, min: 0, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4", placeholder: "km" %>
          <%= f.number_field :distance_m_input, min: 0, max: 999, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4", placeholder: "m" %>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Duration</label>
        <div class="flex space-x-2">
          <%= f.number_field :duration_hours_input, min: 0, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4", placeholder: "hrs" %>
          <%= f.number_field :duration_minutes_input, min: 0, max: 59, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4", placeholder: "min" %>
          <%= f.number_field :duration_seconds_input, min: 0, max: 59, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4", placeholder: "sec" %>
        </div>
      </div>
      <div>
        <%= f.label :challenge_participation_id, "Count toward challenge", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :challenge_participation_id, @participations || [], :id, ->(p) { p.challenge.title }, { include_blank: "None" }, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02] text-base sm:text-sm py-3 px-4" %>
      </div>
      <div>
        <%= f.submit "Add workout", class: "bg-[#FC4C02] text-white px-6 py-2 rounded-lg hover:bg-[#e04402] transition font-medium cursor-pointer" %>
      </div>
    </div>
  <% end %>

  <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent workouts</h2>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <% if @workouts.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sport</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Distance</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Pace</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @workouts.each do |w| %>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900"><%= w.workout_date.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= w.sport&.capitalize %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= w.distance_km %> km</td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= w.duration_minutes %> min</td>
              <td class="px-6 py-4 text-sm text-gray-700">
                <% if w.provider == "manual" && w.distance_km.to_f > 0 && w.duration_minutes.to_f > 0 %>
                  <% pace = w.duration_minutes.to_f / w.distance_km.to_f %>
                  <% pace_min = pace.floor %>
                  <% pace_sec = ((pace - pace_min) * 60).round %>
                  <%= format("%d:%02d /km", pace_min, pace_sec) %>
                <% else %>
                  -
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="p-6 text-gray-500">No workouts yet. Add one above!</p>
    <% end %>
  </div>
</div>
