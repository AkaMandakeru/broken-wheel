<% earned = user_badge.present? %>
<% earned_at_label = earned ? user_badge.earned_at.strftime("%b %d, %Y") : "" %>
<% pct   = progress[:pct] %>
<% kind  = progress[:kind].to_s %>
<% label = progress[:label] %>

<div class="rounded-lg border p-3 text-center transition cursor-pointer hover:shadow-md hover:scale-105 duration-150 <%= earned ? 'bg-white border-gray-200 shadow-sm' : 'bg-gray-50 border-gray-100' %>"
     data-action="click->modal#open"
     data-badge-icon="<%= badge.icon %>"
     data-badge-name="<%= badge.name %>"
     data-badge-title="<%= badge.title %>"
     data-badge-description="<%= badge.description %>"
     data-badge-points="<%= badge.points %>"
     data-badge-earned="<%= earned %>"
     data-badge-earned-at="<%= earned_at_label %>"
     data-badge-progress-pct="<%= pct %>"
     data-badge-progress-label="<%= label %>"
     data-badge-progress-kind="<%= kind %>">

  <div class="text-3xl mb-1 <%= earned ? '' : 'opacity-40' %>"><%= badge.icon %></div>
  <p class="text-xs font-semibold text-gray-900 leading-tight mb-1 <%= 'opacity-50' unless earned %>"><%= badge.name %></p>
  <p class="text-xs font-medium <%= earned ? 'text-[#FC4C02]' : 'text-gray-400' %>"><%= badge.title %></p>
  <p class="text-xs text-gray-400 mt-1"><%= badge.points %> pts</p>

  <% if earned %>
    <div class="mt-2 flex items-center justify-center gap-1">
      <i class="fa-solid fa-circle-check text-green-500 text-xs"></i>
      <span class="text-xs text-green-600"><%= user_badge.earned_at.strftime("%b %Y") %></span>
    </div>
  <% else %>
    <%# Progress bar %>
    <div class="mt-2">
      <div class="w-full bg-gray-200 rounded-full h-1 mb-1">
        <div class="bg-[#FC4C02] h-1 rounded-full transition-all" style="width: <%= pct %>%"></div>
      </div>
      <p class="text-xs text-gray-400"><%= pct %>%</p>
    </div>
  <% end %>
</div>
