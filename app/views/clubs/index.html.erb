<div class="pt-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Communities & Clubs</h1>

  <div class="mb-8">
    <button type="button" onclick="document.getElementById('new-club-form').classList.toggle('hidden')" class="bg-[#FC4C02] text-white px-6 py-2 rounded-lg hover:bg-[#e04402] transition font-medium">
      Create Club
    </button>
  </div>

  <div id="new-club-form" class="hidden bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8 max-w-md">
    <%= form_with model: Club.new, url: clubs_path, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]", required: true %>
        </div>
        <div>
          <%= f.label :sport, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :sport, [["Run", "run"], ["Bike", "bike"], ["Soccer", "soccer"]], { include_blank: "Select sport" }, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]" %>
        </div>
        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-[#FC4C02] focus:ring-[#FC4C02]" %>
        </div>
        <%= f.submit "Create", class: "bg-[#FC4C02] text-white px-6 py-2 rounded-lg hover:bg-[#e04402] transition font-medium cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <% @clubs.each do |club| %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 flex justify-between items-center">
        <div>
          <h2 class="text-lg font-semibold text-gray-900"><%= club.name %></h2>
          <p class="text-sm text-gray-600 mt-1"><%= club.description %></p>
          <div class="flex gap-4 mt-2 text-sm text-gray-500">
            <span><%= club.sport&.capitalize %></span>
            <span><%= club.member_count %> members</span>
          </div>
        </div>
        <% membership = current_user.club_memberships.find_by(club: club) %>
        <% if membership %>
          <%= link_to "View", club_path(club), class: "text-[#FC4C02] hover:underline font-medium" %>
        <% else %>
          <%= button_to "Join", join_club_path(club), method: :post, class: "bg-[#FC4C02] text-white px-4 py-2 rounded-lg hover:bg-[#e04402] transition font-medium cursor-pointer" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @clubs.empty? %>
    <p class="text-gray-500 py-8">No clubs yet. Create one!</p>
  <% end %>
</div>
