<div class="pt-8">
  <%= link_to "← Back to clubs", clubs_path, class: "text-[#FC4C02] hover:underline mb-6 inline-block" %>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @club.name %></h1>
    <p class="text-gray-600 mt-2"><%= @club.description %></p>
    <div class="flex gap-4 mt-4 text-sm text-gray-500">
      <span><%= @club.sport&.capitalize %></span>
      <span><%= @club.member_count %> members</span>
    </div>

    <div class="mt-6">
      <% if @membership %>
        <%= button_to "Leave club", leave_club_path(@club), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:underline text-sm" %>
      <% else %>
        <%= button_to "Join club", join_club_path(@club), method: :post, class: "bg-[#FC4C02] text-white px-6 py-2 rounded-lg hover:bg-[#e04402] transition font-medium cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
